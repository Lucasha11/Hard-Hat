<div class="form-page">
  <h1 class="page-title">Submit a Site Update</h1>
  <p class="page-subtitle">Have new information about an existing construction site? Let us know.</p>

  {{#if error}}
    <div class="alert alert--error">{{error}}</div>
  {{/if}}

  <form method="POST" action="/reports/update" class="form card">
    <div class="form-group">
      <label for="siteId" class="form-label">Building ID (Site ID)</label>
      <input
        type="text"
        id="siteId"
        name="siteId"
        class="form-input"
        value="{{formData.siteId}}"
        placeholder="e.g. 12345"
        required
      />
    </div>

    <div class="form-group">
      <label for="description" class="form-label">What's the update?</label>
      <textarea
        id="description"
        name="description"
        class="form-input form-textarea"
        rows="5"
        maxlength="1000"
        placeholder="Describe what has changed or what new information you have about this site."
        required
      >{{formData.description}}</textarea>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn--primary">Submit Update</button>
      <a href="/my-activity" class="btn btn--secondary">Cancel</a>
    </div>
  </form>
</div>
