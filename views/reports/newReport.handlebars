<div class="form-page">
  <h1 class="page-title">Report a Missing Site</h1>
  <p class="page-subtitle">If a construction site is missing from our dataset, fill out this form to let us know.</p>

  {{#if error}}
    <div class="alert alert--error">{{error}}</div>
  {{/if}}

  <form method="POST" action="/reports/new" class="form card">
    <div class="form-group">
      <label for="siteId" class="form-label">Building ID (Site ID)</label>
      <input
        type="text"
        id="siteId"
        name="siteId"
        class="form-input"
        value="{{formData.siteId}}"
        placeholder="e.g. 12345"
        required
      />
      <p class="form-hint">This is the building ID from NYC Open Data.</p>
    </div>

    <div class="form-group">
      <label for="description" class="form-label">Description</label>
      <textarea
        id="description"
        name="description"
        class="form-input form-textarea"
        rows="5"
        maxlength="1000"
        placeholder="Briefly describe the construction site and why it should be added."
        required
      >{{formData.description}}</textarea>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn--primary">Submit Report</button>
      <a href="/my-activity" class="btn btn--secondary">Cancel</a>
    </div>
  </form>
</div>
