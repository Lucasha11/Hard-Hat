<div class="form-page">
  <div class="form-header">
    <a href="/sites/{{site._id}}" class="back-link">&larr; Back to {{site.schoolName}}</a>
    <h1 class="form-title">Edit Review</h1>
    <p class="form-subtitle">{{site.buildingAddress}}, {{site.borough}}</p>
  </div>

  {{#if error}}
    <div class="alert alert--error">{{error}}</div>
  {{/if}}

  <form method="POST" action="/reviews/{{review._id}}/edit"
        enctype="multipart/form-data" class="review-form card">

    {{! Title }}
    <div class="form-group">
      <label for="title" class="form-label">Review Title <span class="required">*</span></label>
      <input
        type="text"
        id="title"
        name="title"
        class="form-input"
        maxlength="100"
        value="{{review.title}}"
        required
      />
    </div>

    {{! Ratings }}
    <fieldset class="ratings-fieldset">
      <legend class="form-label">Ratings (1 = low impact, 5 = high impact) <span class="required">*</span></legend>
      <div class="ratings-grid">

        <div class="form-group">
          <label for="noise" class="form-label">Noise Level</label>
          <select id="noise" name="noise" class="form-select" required>
            <option value="1" {{selected review.ratings.noise 1}}>1</option>
            <option value="2" {{selected review.ratings.noise 2}}>2</option>
            <option value="3" {{selected review.ratings.noise 3}}>3</option>
            <option value="4" {{selected review.ratings.noise 4}}>4</option>
            <option value="5" {{selected review.ratings.noise 5}}>5</option>
          </select>
        </div>

        <div class="form-group">
          <label for="airQuality" class="form-label">Air Quality Impact</label>
          <select id="airQuality" name="airQuality" class="form-select" required>
            <option value="1" {{selected review.ratings.airQuality 1}}>1</option>
            <option value="2" {{selected review.ratings.airQuality 2}}>2</option>
            <option value="3" {{selected review.ratings.airQuality 3}}>3</option>
            <option value="4" {{selected review.ratings.airQuality 4}}>4</option>
            <option value="5" {{selected review.ratings.airQuality 5}}>5</option>
          </select>
        </div>

        <div class="form-group">
          <label for="constructionSize" class="form-label">Construction Size</label>
          <select id="constructionSize" name="constructionSize" class="form-select" required>
            <option value="1" {{selected review.ratings.constructionSize 1}}>1</option>
            <option value="2" {{selected review.ratings.constructionSize 2}}>2</option>
            <option value="3" {{selected review.ratings.constructionSize 3}}>3</option>
            <option value="4" {{selected review.ratings.constructionSize 4}}>4</option>
            <option value="5" {{selected review.ratings.constructionSize 5}}>5</option>
          </select>
        </div>

        <div class="form-group">
          <label for="workHours" class="form-label">Work Hour Disruption</label>
          <select id="workHours" name="workHours" class="form-select" required>
            <option value="1" {{selected review.ratings.workHours 1}}>1</option>
            <option value="2" {{selected review.ratings.workHours 2}}>2</option>
            <option value="3" {{selected review.ratings.workHours 3}}>3</option>
            <option value="4" {{selected review.ratings.workHours 4}}>4</option>
            <option value="5" {{selected review.ratings.workHours 5}}>5</option>
          </select>
        </div>

      </div>
    </fieldset>

    {{! Review body }}
    <div class="form-group">
      <label for="body" class="form-label">Your Review <span class="required">*</span></label>
      <textarea
        id="body"
        name="body"
        class="form-textarea"
        rows="6"
        maxlength="2000"
        required
      >{{review.body}}</textarea>
    </div>

    {{! Existing photo }}
    {{#if review.photoUrls.length}}
    <div class="form-group">
      <p class="form-label">Current Photo</p>
      {{#each review.photoUrls}}
        <img src="{{this}}" alt="Current review photo" class="review-photo review-photo--preview" />
      {{/each}}
    </div>
    {{/if}}

    {{! Replace photo }}
    <div class="form-group">
      <label for="photo" class="form-label">Replace Photo <span class="optional">(optional)</span></label>
      <input type="file" id="photo" name="photo" class="form-file" accept="image/*" />
      <p class="form-hint">Upload a new photo to replace the existing one. Max 5 MB.</p>
    </div>

    <div class="form-actions">
      <a href="/sites/{{site._id}}" class="btn btn--secondary">Cancel</a>
      <button type="submit" class="btn btn--primary">Save Changes</button>
    </div>
  </form>
</div>
