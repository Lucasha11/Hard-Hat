<div class="form-page">
  <div class="form-header">
    <a href="/sites/{{siteId}}" class="back-link">&larr; Back to {{site.schoolName}}</a>
    <h1 class="form-title">Write a Review</h1>
    <p class="form-subtitle">{{site.buildingAddress}}, {{site.borough}}</p>
  </div>

  {{#if error}}
    <div class="alert alert--error">{{error}}</div>
  {{/if}}

  <form method="POST" action="/sites/{{siteId}}/reviews"
        enctype="multipart/form-data" class="review-form card">

    {{! Title }}
    <div class="form-group">
      <label for="title" class="form-label">Review Title <span class="required">*</span></label>
      <input
        type="text"
        id="title"
        name="title"
        class="form-input"
        maxlength="100"
        placeholder="e.g. Very loud during the morning"
        value="{{formData.title}}"
        required
      />
    </div>

    {{! Ratings }}
    <fieldset class="ratings-fieldset">
      <legend class="form-label">Ratings (1 = low impact, 5 = high impact) <span class="required">*</span></legend>
      <div class="ratings-grid">

        <div class="form-group">
          <label for="noise" class="form-label">Noise Level</label>
          <select id="noise" name="noise" class="form-select" required>
            <option value="1" {{selected formData.noise 1}}>1</option>
            <option value="2" {{selected formData.noise 2}}>2</option>
            <option value="3" {{selected formData.noise 3}}>3</option>
            <option value="4" {{selected formData.noise 4}}>4</option>
            <option value="5" {{selected formData.noise 5}}>5</option>
          </select>
        </div>

        <div class="form-group">
          <label for="airQuality" class="form-label">Air Quality Impact</label>
          <select id="airQuality" name="airQuality" class="form-select" required>
            <option value="1" {{selected formData.airQuality 1}}>1</option>
            <option value="2" {{selected formData.airQuality 2}}>2</option>
            <option value="3" {{selected formData.airQuality 3}}>3</option>
            <option value="4" {{selected formData.airQuality 4}}>4</option>
            <option value="5" {{selected formData.airQuality 5}}>5</option>
          </select>
        </div>

        <div class="form-group">
          <label for="constructionSize" class="form-label">Construction Size</label>
          <select id="constructionSize" name="constructionSize" class="form-select" required>
            <option value="1" {{selected formData.constructionSize 1}}>1</option>
            <option value="2" {{selected formData.constructionSize 2}}>2</option>
            <option value="3" {{selected formData.constructionSize 3}}>3</option>
            <option value="4" {{selected formData.constructionSize 4}}>4</option>
            <option value="5" {{selected formData.constructionSize 5}}>5</option>
          </select>
        </div>

        <div class="form-group">
          <label for="workHours" class="form-label">Work Hour Disruption</label>
          <select id="workHours" name="workHours" class="form-select" required>
            <option value="1" {{selected formData.workHours 1}}>1</option>
            <option value="2" {{selected formData.workHours 2}}>2</option>
            <option value="3" {{selected formData.workHours 3}}>3</option>
            <option value="4" {{selected formData.workHours 4}}>4</option>
            <option value="5" {{selected formData.workHours 5}}>5</option>
          </select>
        </div>

      </div>
    </fieldset>

    {{! Review body }}
    <div class="form-group">
      <label for="body" class="form-label">Your Review <span class="required">*</span></label>
      <textarea
        id="body"
        name="body"
        class="form-textarea"
        rows="6"
        maxlength="2000"
        placeholder="Describe what you saw, heard, or experienced at this site..."
        required
      >{{formData.body}}</textarea>
    </div>

    {{! Photo upload }}
    <div class="form-group">
      <label for="photo" class="form-label">Add a Photo <span class="optional">(optional)</span></label>
      <input type="file" id="photo" name="photo" class="form-file" accept="image/*" />
      <p class="form-hint">Max 5 MB. JPG, PNG, GIF, or WebP.</p>
    </div>

    <div class="form-actions">
      <a href="/sites/{{siteId}}" class="btn btn--secondary">Cancel</a>
      <button type="submit" class="btn btn--primary">Submit Review</button>
    </div>
  </form>
</div>
