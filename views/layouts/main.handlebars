<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{title}} | Hard Hat</title>
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body>
  <nav class="navbar">
    <a href="/" class="nav-logo">Hard Hat</a>
    <div class="search-container" role="search">
      <input
        type="search"
        id="site-search"
        class="search-input"
        placeholder="Search sites or reviews…"
        autocomplete="off"
        aria-label="Search construction sites"
        aria-autocomplete="list"
        aria-controls="search-dropdown"
      />
      <ul id="search-dropdown" class="search-dropdown" role="listbox" hidden></ul>
    </div>
    <div class="nav-links">
      <a href="/stats" class="nav-link">Statistics</a>
      <a href="{{#if isLoggedIn}}/reviews/new{{else}}/{{/if}}" class="btn btn--hazard">Submit a Review</a>
      {{#if isLoggedIn}}
        <a href="/notifications">Notifications</a>
        <a href="/profile" class="nav-link">{{sessionUser.firstName}} {{sessionUser.lastName}}</a>
        <a href="/signout" class="nav-link">Sign Out</a>
      {{else}}
        <a href="/signin" class="nav-link">Sign In</a>
        <a href="/register" class="nav-link nav-link--cta">Register</a>
      {{/if}}
    </div>
  </nav>

  <main class="main-content">
    {{{body}}}
  </main>

  <footer class="footer">
    <p>&copy; 2026 Hard Hat &mdash; NYC Construction Reviews</p>
  </footer>
  <script src="/js/search.js"></script>
</body>
</html>
